# Text-only LLM (anchor extraction). DeepSeek is OpenAI-compatible.
DEEPSEEK_API_KEY=sk-...

# Vision-capable LLM (single-image scoring + pairwise comparison).
# Defaults below target the public OpenAI endpoint with gpt-4o-mini.
# Swap to any OpenAI-compatible vision endpoint (Qwen-VL, GLM-4V, internal proxies, etc.) without code changes.
VISION_API_KEY=sk-...
VISION_BASE_URL=https://api.openai.com/v1
VISION_MODEL=gpt-4o-mini
